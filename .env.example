# Environment variables
# Rename this file to .env and insert your API keys.

# GitHub API Key for the GitHub MCP server
# Generate a Personal Access Token (classic) with "repo" scope at:
# https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here

# Google Custom Search API Keys for the Google Search MCP server
# 1. Get an API key from Google Cloud Console (Custom Search API): https://developers.google.com/custom-search/v1/introduction
# 2. Setup a Programmable Search Engine to get a CX (Search Engine ID): https://programmablesearchengine.google.com/
GOOGLE_API_KEY=your_google_api_key_here
CUSTOM_SEARCH_ENGINE_ID=your_custom_search_engine_id_here
