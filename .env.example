# Environment variables
# Rename this file to .env and insert your API keys.

# GitHub API Key for the GitHub MCP server
# Generate a Personal Access Token (classic) with "repo" scope at:
# https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here



# Brave Search API Key for the Web Search MCP server
# Get a free API key at: https://brave.com/search/api/
BRAVE_API_KEY=your_brave_api_key_here

# General Information MCP Configuration
USER_PROFILE="Lives at Usbenztanian (Border of Helsinki/Vantaa). Consider Helsinki/vantaa as local."
WEATHER_LOCATION=Helsinki
USER_TIMEZONE=Europe/Helsinki
