FROM mcr.microsoft.com/playwright:v1.43.0-jammy

WORKDIR /app

# Install dependencies
COPY package.json ./
RUN npm install

# Set up Playwright to use a specific, predictable path
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=0

# We will try to install 'chrome' specifically as requested by the error message
RUN npx playwright install chrome

COPY server.js ./

# Use the correct package name
ENTRYPOINT ["node", "server.js", "npx", "-y", "@playwright/mcp"]
